// AVELIS — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum CopyStatus {
  AVAILABLE
  BORROWED
  LOST
  MAINTENANCE
}

enum CopyCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
}

enum LoanStatus {
  BORROWED
  RETURNED
  OVERDUE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PLACED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  phone        String?
  avatar       String?
  role         UserRole @default(MEMBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  loans        Loan[]
}

model Author {
  id        String       @id @default(uuid())
  fullName  String
  biography String?
  photo     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  books     BookAuthor[]
}

model Category {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  books       BookCategory[]
}

model Book {
  id              String         @id @default(uuid())
  title           String
  isbn            String         @unique
  publisher       String?
  publicationYear Int?
  language        String         @default("English")
  description     String?
  coverImage      String?
  sellingPrice    Decimal        @default(0)
  stockQuantity   Int            @default(0)
  isBorrowable    Boolean        @default(true)
  isForSale       Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  authors         BookAuthor[]
  categories      BookCategory[]
  copies          BookCopy[]
}

model BookAuthor {
  id       String @id @default(uuid())
  bookId   String
  authorId String
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([bookId, authorId])
  @@index([bookId])
  @@index([authorId])
}

model BookCategory {
  id         String   @id @default(uuid())
  bookId     String
  categoryId String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([bookId, categoryId])
  @@index([bookId])
  @@index([categoryId])
}

model BookCopy {
  id            String        @id @default(uuid())
  bookId        String
  barcode       String        @unique
  shelfLocation String?
  condition     CopyCondition @default(NEW)
  status        CopyStatus    @default(AVAILABLE)
  purchaseDate  DateTime?     @db.Date
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  book          Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  loans         Loan[]

  @@index([bookId])
  @@index([barcode])
}

model Loan {
  id         String     @id @default(uuid())
  userId     String
  copyId     String
  issueDate  DateTime
  dueDate    DateTime
  returnDate DateTime?
  fineAmount Decimal    @default(0)
  status     LoanStatus
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  bookCopy   BookCopy   @relation(fields: [copyId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([copyId])
}


