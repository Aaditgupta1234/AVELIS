# ============================================
# AVELIS Server — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.
# ============================================

# Application
NODE_ENV=development
PORT=5000

# CORS
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

DATABASE_URL="postgresql://<USERNAME>:<PASSWORD>@localhost:5432/avelis_db?schema=public"

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d
